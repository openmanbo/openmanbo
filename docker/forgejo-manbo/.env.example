# OpenAI-compatible API key (required)
OPENAI_API_KEY=sk-your-key-here

# OpenAI-compatible API base URL (optional, defaults to https://api.openai.com/v1)
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Model name (optional, defaults to gpt-4o)
OPENAI_MODEL=gpt-4o

# Tavily API key (required for the Tavily MCP server)
TAVILY_API_KEY=

# Forgejo configuration (required for the Forgejo MCP server)
FORGEJO_URL=
FORGEJO_TOKEN=

# Anthropic configuration (optional, required for using Claude Code)
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=

# File Browser configuration (optional)
# Exposed at http://localhost:8080 by docker/docker-compose.yml
OPENMANBO_FILEBROWSER_PORT=8080
OPENMANBO_FILEBROWSER_ROOT=/app/.openmanbo
OPENMANBO_FILEBROWSER_DATABASE=/workspace/.filebrowser/filebrowser.db
