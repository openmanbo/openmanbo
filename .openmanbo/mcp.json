{
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": {
        "TAVILY_API_KEY": "your-tavily-api-key"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${dataDir}/filesystem"
      ]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "${dataDir}/memory.jsonl"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "forgejo": {
      "command": "node",
      "args": ["${dataDir}/forgejo-mcp/dist/index.js"],
      "env": {
        "FORGEJO_URL": "https://forgejo.example.com",
        "FORGEJO_TOKEN": "your-forgejo-token"
      }
    }
  },
  "builtinTools": {
    "exec": {
      "enabled": true,
      "name": "exec",
      "description": "Run allowlisted workspace commands only.",
      "cwd": "${workspaceDir}",
      "timeoutMs": 600000,
      "maxOutputChars": 100000,
      "env": {
        "ANTHROPIC_BASE_URL": "${env:ANTHROPIC_BASE_URL}",
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
        "ANTHROPIC_MODEL": "${env:ANTHROPIC_MODEL}"
      },
      "mode": "blacklist",
      "blacklist": [
        { "pattern": "rm\\s+-rf\\s+/.*", "description": "Block recursive forced deletion from root" },
        { "pattern": "(?:sudo|doas)\\s+.*", "description": "Block privilege escalation" }
      ]
    },
    "reflection": {
      "enabled": true,
      "name": "self-reflection",
      "description": "Review the last completed task, identify misses or risks, and suggest concrete adjustments before continuing."
    }
  }
}
