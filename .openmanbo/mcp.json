{
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": {
        "TAVILY_API_KEY": "your-tavily-api-key"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${dataDir}/filesystem"
      ]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "${dataDir}/memory.jsonl"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  },
  "builtinTools": {
    "exec": {
      "enabled": true,
      "name": "builtin_exec",
      "description": "Run allowlisted workspace commands only.",
      "cwd": "${workspaceDir}",
      "timeoutMs": 15000,
      "maxOutputChars": 8000,
      "allowlist": [
        {
          "pattern": "date",
          "description": "Get the current date and time."
        },
        {
          "pattern": "which(?:\\s+[A-Za-z0-9._-]+)+",
          "description": "Locate an executable in PATH."
        },
        {
          "pattern": "claude(?:\\s+[A-Za-z0-9._:/=,@+-]+)*",
          "description": "Run the Claude CLI with simple arguments."
        },
        {
          "pattern": "gemini(?:\\s+[A-Za-z0-9._:/=,@+-]+)*",
          "description": "Run the Gemini CLI with simple arguments."
        }
      ]
    }
  }
}
