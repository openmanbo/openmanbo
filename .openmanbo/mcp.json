{
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": {
        "TAVILY_API_KEY": "your-tavily-api-key"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${dataDir}/filesystem"
      ]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "${dataDir}/memory.jsonl"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  },
  "builtinTools": {
    "exec": {
      "enabled": true,
      "name": "exec",
      "description": "Run allowlisted workspace commands only.",
      "cwd": "${workspaceDir}",
      "timeoutMs": 600000,
      "maxOutputChars": 100000,
      "env": {
        "ANTHROPIC_BASE_URL": "${env:ANTHROPIC_BASE_URL}",
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
        "ANTHROPIC_MODEL": "${env:ANTHROPIC_MODEL}"
      },
      "allowlist": [
        {
          "pattern": "date",
          "description": "Get the current date and time."
        },
        {
          "pattern": "which(?:\\s+[A-Za-z0-9._-]+)+",
          "description": "Locate an executable in PATH."
        },
        {
          "pattern": "(?:claude|[^\\s]*/claude)(?:\\s+(?:[A-Za-z0-9._:/=,@+-]+|\"[^\"\\r\\n]*\"|'[^'\\r\\n]*'))*",
          "description": "Run the Claude CLI with common arguments, including quoted values."
        },
        {
          "pattern": "(?:obsidian|[^\\s]*/obsidian)(?:\\s+(?:[A-Za-z0-9._:/=,@+-]+|[A-Za-z0-9._:/,@+-]+=(?:[A-Za-z0-9._:/=,@+-]+|\"[^\"\\r\\n]*\"|'[^'\\r\\n]*')|\"[^\"\\r\\n]*\"|'[^'\\r\\n]*'))*",
          "description": "Run Obsidian CLI commands, including read/search with quoted arguments."
        }
      ]
    }
  }
}
