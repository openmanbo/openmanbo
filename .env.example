# OpenAI-compatible API key (required)
OPENAI_API_KEY=sk-your-key-here

# OpenAI-compatible API base URL (optional, defaults to https://api.openai.com/v1)
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Model name (optional, defaults to gpt-4o)
OPENAI_MODEL=gpt-4o

# Discord bot token (required for the discord channel)
DISCORD_BOT_TOKEN=

# Tavily API key (required for the Tavily MCP server)
TAVILY_API_KEY=